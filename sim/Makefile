#=============================================================================
# Makefile - 异步FIFO VCS仿真脚本
# 仿真工具: VCS 2018.09-SP2
# 波形工具: Verdi
# 日期:     2026-03-09
#=============================================================================

#-----------------------------------------------------------------------------
# 变量定义 (Variable Definitions)
#-----------------------------------------------------------------------------
# VCS编译器路径（使用系统默认路径，如需修改请设置VCS_HOME环境变量）
VCS      = vcs

# Verdi波形查看器
VERDI    = verdi

# 源文件列表
FILELIST = filelist.f

# 仿真可执行文件名
SIMV     = simv

# FSDB波形文件名
FSDB     = async_fifo.fsdb

# VCS编译选项说明：
#   -full64          : 64位编译模式
#   -sverilog        : 支持SystemVerilog语法
#   -debug_access+all: 开启完整调试访问（Verdi波形转储所需）
#   -timescale=1ns/1ps: 设置默认时间精度
#   -f $(FILELIST)   : 指定源文件列表
#   +v2k             : 支持Verilog-2001语法
#   -l compile.log   : 编译日志输出到文件
#   -kdb             : 生成Verdi KDB数据库（加速波形加载）
#   +define+FSDB_DUMP: 定义宏，用于条件编译波形转储代码
VCS_OPTS = -full64 \
           -sverilog \
           +v2k \
           -debug_access+all \
           -timescale=1ns/1ps \
           -f $(FILELIST) \
           -l compile.log \
           -kdb \
           -o $(SIMV)

# 仿真运行选项说明：
#   -l run.log       : 运行日志输出到文件
RUN_OPTS = -l run.log

# Verdi选项说明：
#   -ssf $(FSDB)     : 指定FSDB波形文件
#   -f $(FILELIST)   : 指定源文件列表（用于信号名关联）
VERDI_OPTS = -ssf $(FSDB) -f $(FILELIST)

#-----------------------------------------------------------------------------
# 编译目标 (Compile Target)
# 将RTL源文件和Testbench编译为仿真可执行文件
#-----------------------------------------------------------------------------
compile:
	@echo "=========================================="
	@echo " [编译] 正在编译异步FIFO设计..."
	@echo "=========================================="
	$(VCS) $(VCS_OPTS)
	@echo " [编译完成] 生成仿真文件: $(SIMV)"

#-----------------------------------------------------------------------------
# 运行目标 (Run Target)
# 执行仿真，生成FSDB波形文件和运行日志
#-----------------------------------------------------------------------------
run: compile
	@echo "=========================================="
	@echo " [仿真] 正在运行异步FIFO仿真..."
	@echo "=========================================="
	./$(SIMV) $(RUN_OPTS)
	@echo " [仿真完成] 波形文件: $(FSDB), 日志: run.log"

#-----------------------------------------------------------------------------
# Verdi波形查看目标 (Verdi Waveform Viewer Target)
# 打开Verdi加载FSDB波形进行分析
#-----------------------------------------------------------------------------
verdi:
	@echo "=========================================="
	@echo " [Verdi] 正在打开波形查看器..."
	@echo "=========================================="
	$(VERDI) $(VERDI_OPTS) &

#-----------------------------------------------------------------------------
# 完整流程目标 (Full Flow Target)
# 依次执行：编译 → 仿真运行
#-----------------------------------------------------------------------------
all: compile run
	@echo " [全流程完成]"

#-----------------------------------------------------------------------------
# 清理目标 (Clean Target)
# 删除所有生成的中间文件和仿真产物
#-----------------------------------------------------------------------------
clean:
	@echo "=========================================="
	@echo " [清理] 正在删除生成文件..."
	@echo "=========================================="
	rm -rf $(SIMV) $(SIMV).daidir     # 删除仿真可执行文件及其目录
	rm -rf csrc                        # 删除VCS编译中间文件目录
	rm -rf *.fsdb                      # 删除FSDB波形文件
	rm -rf *.log                       # 删除日志文件
	rm -rf *.key                       # 删除Synopsys密钥文件
	rm -rf novas.*                     # 删除Verdi临时文件
	rm -rf verdiLog                    # 删除Verdi日志目录
	rm -rf *.vpd                       # 删除VPD波形文件
	rm -rf DVEfiles                    # 删除DVE文件
	rm -rf ucli.key                    # 删除UCLI密钥文件
	rm -rf inter.vpd                   # 删除交互式VPD文件
	rm -rf .vlogansetup.args           # 删除vlogan配置文件
	@echo " [清理完成]"

#-----------------------------------------------------------------------------
# 声明伪目标 (Phony Targets)
# 防止make将目标名与同名文件混淆
#-----------------------------------------------------------------------------
.PHONY: compile run verdi all clean
