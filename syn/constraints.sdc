#=============================================================================
# SDC约束文件 - 异步FIFO (Asynchronous FIFO Timing Constraints)
# 综合工具: Design Compiler 2018.06-SP1
# 日期:     2026-03-09
#
# 说明: 本文件定义异步FIFO的时钟、输入输出延迟、以及跨时钟域约束
#=============================================================================

#-----------------------------------------------------------------------------
# 1. 时钟定义 (Clock Definitions)
#    定义两个异步时钟域的时钟约束
#-----------------------------------------------------------------------------

# 写时钟: 100MHz, 周期10ns, 占空比50%
# 端口clk_wr为写时钟输入引脚
create_clock -name clk_wr -period 10.0 -waveform {0 5.0} [get_ports clk_wr]

# 读时钟: 50MHz, 周期20ns, 占空比50%
# 端口clk_rd为读时钟输入引脚
create_clock -name clk_rd -period 20.0 -waveform {0 10.0} [get_ports clk_rd]

#-----------------------------------------------------------------------------
# 2. 时钟不确定性 (Clock Uncertainty)
#    考虑时钟抖动(Jitter)和偏移(Skew)的影响
#    建立时间裕量: 0.2ns (根据工艺库和时钟树特性调整)
#-----------------------------------------------------------------------------

# 写时钟不确定性: 建立时间裕量0.2ns
set_clock_uncertainty -setup 0.2 [get_clocks clk_wr]

# 读时钟不确定性: 建立时间裕量0.2ns
set_clock_uncertainty -setup 0.2 [get_clocks clk_rd]

# 保持时间不确定性(可选): 0.05ns
set_clock_uncertainty -hold 0.05 [get_clocks clk_wr]
set_clock_uncertainty -hold 0.05 [get_clocks clk_rd]

#-----------------------------------------------------------------------------
# 3. 时钟转换时间 (Clock Transition)
#    限制时钟边沿的上升/下降时间，防止时钟信号退化
#-----------------------------------------------------------------------------

# 写时钟最大转换时间: 0.1ns
set_clock_transition -max 0.1 [get_clocks clk_wr]

# 读时钟最大转换时间: 0.1ns
set_clock_transition -max 0.1 [get_clocks clk_rd]

#-----------------------------------------------------------------------------
# 4. 输入延迟约束 (Input Delay Constraints)
#    定义输入信号相对于时钟边沿的到达时间
#    输入延迟 = 外部寄存器Tco + PCB走线延迟
#    此处假设输入延迟为时钟周期的30%
#-----------------------------------------------------------------------------

# 写端口输入延迟(相对于写时钟clk_wr)
# wr_en和din在clk_wr上升沿后3ns到达(30% × 10ns)
set_input_delay
